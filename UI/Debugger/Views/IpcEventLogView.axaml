<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Mesen.Debugger.ViewModels"
	mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="300"
	VerticalAlignment="Stretch"
	HorizontalAlignment="Stretch"
	x:DataType="vm:IpcEventLogViewModel"
	x:Class="Mesen.Debugger.Views.IpcEventLogView"
>
	<UserControl.Styles>
		<Style Selector="ListBox">
			<Setter Property="FontFamily" Value="Consolas, Menlo, monospace" />
			<Setter Property="FontSize" Value="12" />
		</Style>
	</UserControl.Styles>

	<DockPanel>
		<DockPanel DockPanel.Dock="Bottom" LastChildFill="False">
			<ToggleButton
				Name="ScrollLockToggle"
				DockPanel.Dock="Right"
				IsChecked="True"
				Content="Scroll Lock"
				FontSize="10"
				Padding="6 2"
				Margin="4 2"
				Click="OnScrollLockClick"
			/>
		</DockPanel>
		<Border BorderThickness="0 1 0 0" BorderBrush="{StaticResource MesenGrayBorderColor}">
			<ListBox
				ItemsSource="{Binding Events}"
				Name="EventList"
				SelectionMode="Single"
			>
				<ListBox.ItemTemplate>
					<DataTemplate DataType="{x:Type vm:IpcEventEntry}">
						<StackPanel Orientation="Horizontal" Spacing="8" Margin="2">
							<TextBlock Text="{Binding TimeDisplay}" Foreground="Gray" Width="80" />
							<TextBlock Text="{Binding StatusDisplay}" FontWeight="Bold" Width="30"
								Foreground="{Binding StatusColor}" />
							<TextBlock Text="{Binding Command}" FontWeight="SemiBold" Width="140" />
							<TextBlock Text="{Binding ResponsePreview}" Foreground="Gray" TextTrimming="CharacterEllipsis" />
						</StackPanel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</Border>
	</DockPanel>
</UserControl>
