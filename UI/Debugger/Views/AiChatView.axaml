<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Mesen.Debugger.ViewModels"
	xmlns:c="using:Mesen.Controls"
	xmlns:cfg="using:Mesen.Config"
	mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
	x:DataType="vm:AiCompanionViewModel"
	x:Class="Mesen.Debugger.Views.AiChatView"
>
	<DockPanel>

		<!-- Header bar: monitor + context status + model label + clear -->
		<Border DockPanel.Dock="Top"
			BorderThickness="0,0,0,1"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4,3">
			<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
				<TextBlock Grid.Column="0" Text="Monitor:" FontSize="11"
					VerticalAlignment="Center" Margin="0,0,4,0" />
				<c:EnumComboBox Grid.Column="1"
					SelectedItem="{Binding Config.MonitoringMode}"
					FontSize="11" />
				<TextBlock Grid.Column="2" Margin="6,0,0,0" FontSize="11"
					VerticalAlignment="Center"
					Text="{Binding ContextStatusText}"
					Foreground="{StaticResource MesenTextMutedColor}"
					FontStyle="Italic"
					ToolTip.Tip="Context file status — load or clear in Settings" />
				<TextBlock Grid.Column="3" Margin="6,0,0,0" FontSize="11"
					VerticalAlignment="Center"
					Text="{Binding Config.Model}"
					Foreground="{StaticResource MesenTextMutedColor}"
					ToolTip.Tip="Active model — change in Settings" />
				<Button Grid.Column="4" Margin="4,0,0,0" Padding="6,2"
					Command="{Binding ClearCommand}"
					ToolTip.Tip="Clear chat history">
					<TextBlock Text="Clear" FontSize="11" />
				</Button>
			</Grid>
		</Border>

		<!-- Status bar -->
		<Border DockPanel.Dock="Bottom"
			BorderThickness="0,1,0,0"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4,2">
			<Grid ColumnDefinitions="*,Auto">
				<TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="11"
					VerticalAlignment="Center"
					Foreground="{StaticResource MesenTextMutedColor}" />
				<CheckBox Grid.Column="1" Content="Lock" FontSize="11"
					IsChecked="{Binding ChatScrollLocked}"
					ToolTip.Tip="Auto-scroll chat to the latest message"
					VerticalAlignment="Center" Margin="4,0,0,0" />
			</Grid>
		</Border>

		<!-- Input row -->
		<Border DockPanel.Dock="Bottom"
			BorderThickness="0,1,0,0"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4">
			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
				<TextBox Grid.Column="0"
					x:Name="txtInput"
					Text="{Binding InputText}"
					Watermark="Ask Claude... (Enter to send, Shift+Enter for newline)"
					AcceptsReturn="True"
					TextWrapping="Wrap"
					MinHeight="28"
					MaxHeight="100"
					ScrollViewer.VerticalScrollBarVisibility="Auto"
					FontSize="12"
					VerticalContentAlignment="Center"
					KeyDown="OnInputKeyDown" />
				<Button Grid.Column="1" Margin="4,0,0,0" Padding="10,4"
					VerticalAlignment="Bottom"
					Click="OnSendCancelClick">
					<Panel>
						<TextBlock Text="Send"
							IsVisible="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
						<TextBlock Text="Cancel"
							IsVisible="{Binding IsBusy}" />
					</Panel>
				</Button>
			</Grid>
		</Border>

		<!-- Message list -->
		<ScrollViewer x:Name="chatScroll" HorizontalScrollBarVisibility="Disabled"
			ScrollChanged="OnChatScrollChanged">
			<ItemsControl ItemsSource="{Binding Messages}" Margin="4">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:ChatEntry">
						<Panel Margin="2,3">

							<!-- User message: right-aligned bubble -->
							<Border IsVisible="{Binding IsUser}"
								Background="{StaticResource MesenBlueColor}"
								CornerRadius="6" Padding="8,5"
								HorizontalAlignment="Right" MaxWidth="480">
								<SelectableTextBlock Text="{Binding Text}"
									Foreground="White"
									TextWrapping="Wrap" FontSize="12" />
							</Border>

							<!-- Assistant message: left-aligned bubble -->
							<Border IsVisible="{Binding IsAssistant}"
								Background="{StaticResource MesenGreenColor}"
								CornerRadius="6" Padding="8,5"
								HorizontalAlignment="Left" MaxWidth="560">
								<StackPanel>
									<SelectableTextBlock Text="{Binding Text}"
										Foreground="White"
										TextWrapping="Wrap" FontSize="12" />
									<TextBlock IsVisible="{Binding IsStreaming}"
										Text="▌" FontSize="12" Foreground="White" Opacity="0.5" />
								</StackPanel>
							</Border>

							<!-- Tool status: centered, muted italic -->
							<Border IsVisible="{Binding IsToolStatus}"
								Padding="4,1" HorizontalAlignment="Center">
								<SelectableTextBlock Text="{Binding Text}"
									FontSize="11"
									Foreground="{StaticResource MesenTextMutedColor}"
									FontStyle="Italic" />
							</Border>

							<!-- System message: centered, muted -->
							<Border IsVisible="{Binding IsSystem}"
								Padding="4,1" HorizontalAlignment="Center">
								<SelectableTextBlock Text="{Binding Text}"
									FontSize="11"
									Foreground="{StaticResource MesenTextMutedColor}"
									TextWrapping="Wrap" />
							</Border>

							<!-- Error: red banner -->
							<Border IsVisible="{Binding IsError}"
								Background="{StaticResource MesenErrorColor}"
								CornerRadius="4" Padding="8,5"
								HorizontalAlignment="Stretch">
								<SelectableTextBlock Text="{Binding Text}"
									Foreground="White"
									TextWrapping="Wrap" FontSize="12" />
							</Border>

						</Panel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

	</DockPanel>
</UserControl>
