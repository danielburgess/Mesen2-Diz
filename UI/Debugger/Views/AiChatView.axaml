<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Mesen.Debugger.ViewModels"
	xmlns:c="using:Mesen.Controls"
	xmlns:cfg="using:Mesen.Config"
	xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
	mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
	x:DataType="vm:AiCompanionViewModel"
	x:Class="Mesen.Debugger.Views.AiChatView"
>
	<DockPanel>

		<!-- Header bar -->
		<Border DockPanel.Dock="Top"
			BorderThickness="0,0,0,1"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4,3">
			<Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">

				<!-- Context file -->
				<TextBlock Grid.Column="0" Margin="0,0,2,0" FontSize="11"
					VerticalAlignment="Center"
					Text="{Binding ContextStatusText}"
					Foreground="{StaticResource MesenTextMutedColor}"
					FontStyle="Italic"
					ToolTip.Tip="Context file loaded into every prompt" />
				<Button Grid.Column="1" Padding="4,1" FontSize="11"
					Click="OnLoadContextClick"
					ToolTip.Tip="Load a context file (.txt / .md)">
					<TextBlock Text="ctx…" FontSize="11" />
				</Button>
				<Button Grid.Column="2" Padding="4,1" FontSize="11"
					Command="{Binding ClearContextCommand}"
					IsVisible="{Binding Config.ContextFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
					ToolTip.Tip="Clear context file">
					<TextBlock Text="✕" FontSize="11" />
				</Button>

				<!-- Provider + model (read-only; configure in Debugger Settings) -->
				<TextBlock Grid.Column="3" Margin="8,0,0,0" FontSize="11"
					VerticalAlignment="Center"
					Text="{Binding ProviderModelDisplay}"
					Foreground="{StaticResource MesenTextMutedColor}"
					ToolTip.Tip="Active provider and model — configure in Debugger Settings → AI Companion" />

				<!-- History button -->
				<Button Grid.Column="4" Margin="4,0,0,0" Padding="6,2"
					IsEnabled="{Binding HasArchivedSessions}"
					ToolTip.Tip="Browse previous chat sessions">
					<Button.Flyout>
						<Flyout Placement="BottomEdgeAlignedRight">
							<Border Padding="4" MinWidth="230">
								<ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Disabled">
									<ItemsControl ItemsSource="{Binding ArchivedSessions}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:ChatHistoryEntry">
												<Button Content="{Binding DisplayText}"
													HorizontalAlignment="Stretch"
													HorizontalContentAlignment="Left"
													Click="OnHistorySessionClick"
													Tag="{Binding}"
													Padding="6,4" FontSize="11"
													Margin="0,1"
													Background="Transparent" />
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</ScrollViewer>
							</Border>
						</Flyout>
					</Button.Flyout>
					<TextBlock Text="History" FontSize="11" />
				</Button>

				<!-- Clear chat -->
				<Button Grid.Column="5" Margin="4,0,0,0" Padding="6,2"
					Command="{Binding ClearCommand}"
					ToolTip.Tip="Clear chat history">
					<TextBlock Text="Clear" FontSize="11" />
				</Button>
			</Grid>
		</Border>

		<!-- History banner (visible when browsing an archived session) -->
		<Border DockPanel.Dock="Top"
			IsVisible="{Binding IsViewingHistory}"
			BorderThickness="0,0,0,1"
			BorderBrush="{StaticResource MesenBorderColor}"
			Background="{StaticResource MesenGrayBackgroundColor}"
			Padding="6,3">
			<Grid ColumnDefinitions="*,Auto">
				<TextBlock Grid.Column="0"
					Text="{Binding HistorySessionLabel}"
					FontSize="11" FontStyle="Italic"
					Foreground="{StaticResource MesenTextMutedColor}"
					VerticalAlignment="Center" />
				<Button Grid.Column="1" Padding="6,2" FontSize="11"
					Command="{Binding BackToLiveCommand}"
					ToolTip.Tip="Return to the live chat session">
					<TextBlock Text="← Live" FontSize="11" />
				</Button>
			</Grid>
		</Border>

		<!-- Status bar -->
		<Border DockPanel.Dock="Bottom"
			BorderThickness="0,1,0,0"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4,2">
			<Grid ColumnDefinitions="*,Auto">
				<TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="11"
					VerticalAlignment="Center"
					Foreground="{StaticResource MesenTextMutedColor}" />
				<CheckBox Grid.Column="1" Content="Lock" FontSize="11"
					IsChecked="{Binding ChatScrollLocked}"
					ToolTip.Tip="Auto-scroll chat to the latest message"
					VerticalAlignment="Center" Margin="4,0,0,0" />
			</Grid>
		</Border>

		<!-- Input row (hidden when viewing history) -->
		<Border DockPanel.Dock="Bottom"
			IsVisible="{Binding IsViewingHistory, Converter={x:Static BoolConverters.Not}}"
			BorderThickness="0,1,0,0"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4">
			<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
				<TextBox Grid.Column="0"
					x:Name="txtInput"
					Text="{Binding InputText}"
					Watermark="{Binding InputWatermark}"
					AcceptsReturn="True"
					TextWrapping="Wrap"
					MinHeight="28"
					MaxHeight="84"
					ScrollViewer.VerticalScrollBarVisibility="Auto"
					FontSize="12"
					VerticalContentAlignment="Top" />
				<Button Grid.Column="1" Margin="4,0,0,0" Padding="10,4"
					VerticalAlignment="Bottom"
					Click="OnSendCancelClick">
					<Panel>
						<TextBlock Text="Send"
							IsVisible="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
						<TextBlock Text="Cancel"
							IsVisible="{Binding IsBusy}" />
					</Panel>
				</Button>
			</Grid>
		</Border>

		<!-- Message list -->
		<ScrollViewer x:Name="chatScroll" HorizontalScrollBarVisibility="Disabled"
			ScrollChanged="OnChatScrollChanged">
			<ItemsControl ItemsSource="{Binding ActiveMessages}" Margin="4">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:ChatEntry">
						<Panel Margin="2,3">

							<!-- User message: right-aligned bubble -->
							<Border IsVisible="{Binding IsUser}"
								Background="{StaticResource MesenBlueColor}"
								CornerRadius="6" Padding="8,5"
								HorizontalAlignment="Right" MaxWidth="480">
								<StackPanel>
									<SelectableTextBlock Text="{Binding Text}"
										Foreground="White"
										TextWrapping="Wrap" FontSize="12" />
									<Button HorizontalAlignment="Right" Click="OnCopyClick"
										Margin="0,4,0,0" Padding="4,1" FontSize="10"
										Background="Transparent" BorderThickness="0"
										Foreground="White" Opacity="0.7" Cursor="Hand"
										ToolTip.Tip="Copy to clipboard">
										<TextBlock Text="⎘ copy" FontSize="10" />
									</Button>
								</StackPanel>
							</Border>

							<!-- Assistant message: left-aligned bubble -->
							<Border IsVisible="{Binding IsAssistant}"
								Background="{StaticResource MesenGreenColor}"
								CornerRadius="6" Padding="8,5"
								HorizontalAlignment="Left" MaxWidth="560">
								<StackPanel>
									<!-- Streaming: plain text with animated ellipsis indicator -->
									<SelectableTextBlock IsVisible="{Binding IsStreaming}"
										Text="{Binding Text}"
										TextWrapping="Wrap" FontSize="12" />
									<TextBlock IsVisible="{Binding IsStreaming}"
										Text="{Binding StreamingIndicator}"
										FontSize="12" Opacity="0.6" />

									<!-- Completed: rendered markdown -->
									<md:MarkdownScrollViewer
										IsVisible="{Binding IsStreaming, Converter={x:Static BoolConverters.Not}}"
										Markdown="{Binding Text}"
										MarkdownStyleName="GithubLike"
										SelectionEnabled = "true"
										HorizontalAlignment="Stretch" />

									<Button HorizontalAlignment="Right" Click="OnCopyClick"
										Margin="0,4,0,0" Padding="4,1" FontSize="10"
										Background="Transparent" BorderThickness="0"
										Opacity="0.7" Cursor="Hand"
										ToolTip.Tip="Copy to clipboard">
										<TextBlock Text="⎘ copy" FontSize="10" />
									</Button>
								</StackPanel>
							</Border>

							<!-- Tool status: centered, muted italic -->
							<Border IsVisible="{Binding IsToolStatus}"
								Padding="4,1" HorizontalAlignment="Center">
								<SelectableTextBlock Text="{Binding Text}"
									FontSize="11"
									Foreground="{StaticResource MesenTextMutedColor}"
									FontStyle="Italic" />
							</Border>

							<!-- System message: centered, muted -->
							<Border IsVisible="{Binding IsSystem}"
								Padding="4,1" HorizontalAlignment="Center">
								<SelectableTextBlock Text="{Binding Text}"
									FontSize="11"
									Foreground="{StaticResource MesenTextMutedColor}"
									TextWrapping="Wrap" />
							</Border>

							<!-- Error: red banner -->
							<Border IsVisible="{Binding IsError}"
								Background="{StaticResource MesenErrorColor}"
								CornerRadius="4" Padding="8,5"
								HorizontalAlignment="Stretch">
								<StackPanel>
									<SelectableTextBlock Text="{Binding Text}"
										Foreground="White"
										TextWrapping="Wrap" FontSize="12" />
									<Button HorizontalAlignment="Right" Click="OnCopyClick"
										Margin="0,4,0,0" Padding="4,1" FontSize="10"
										Background="Transparent" BorderThickness="0"
										Foreground="White" Opacity="0.7" Cursor="Hand"
										ToolTip.Tip="Copy to clipboard">
										<TextBlock Text="⎘ copy" FontSize="10" />
									</Button>
								</StackPanel>
							</Border>

						</Panel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

	</DockPanel>
</UserControl>
