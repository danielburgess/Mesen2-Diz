<Window
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:Mesen.Debugger.ViewModels"
	xmlns:ai="using:Mesen.Debugger.AI"
	xmlns:c="using:Mesen.Controls"
	xmlns:l="using:Mesen.Localization"
	mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="700"
	x:Class="Mesen.Debugger.Windows.AiCompanionWindow"
	x:DataType="vm:AiCompanionViewModel"
	Width="620" Height="700" MinWidth="400" MinHeight="400"
	Title="{l:Translate wndTitle}"
>
	<DockPanel>

		<!-- ── Settings / status bar ── -->
		<Border DockPanel.Dock="Top"
			BorderThickness="0,0,0,1"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="6,4">
			<Grid ColumnDefinitions="Auto,*,Auto,Auto">

				<TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0"
					Text="Model:" FontSize="11" />
				<TextBox Grid.Column="1" Text="{Binding Config.Model}"
					FontSize="11" Padding="3,2" VerticalAlignment="Center" />

				<c:EnumComboBox Grid.Column="2" Margin="6,0,0,0"
					SelectedItem="{Binding Config.MonitoringMode}"
					ToolTip.Tip="Monitor execution and detect unannotated code" />

				<Button Grid.Column="3" Margin="4,0,0,0" Padding="6,2"
					Command="{Binding ClearCommand}"
					ToolTip.Tip="Clear chat history">
					<TextBlock Text="Clear" FontSize="11" />
				</Button>
			</Grid>
		</Border>

		<!-- ── API Key row ── -->
		<Border DockPanel.Dock="Top"
			BorderThickness="0,0,0,1"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="6,3">
			<Grid ColumnDefinitions="Auto,*">
				<TextBlock Grid.Column="0" Text="API Key:" FontSize="11"
					VerticalAlignment="Center" Margin="0,0,6,0" />
				<TextBox Grid.Column="1" Text="{Binding Config.ApiKey}"
					PasswordChar="•" FontSize="11" Padding="3,2"
					ToolTip.Tip="Your Anthropic API key (stored in debugger config)" />
			</Grid>
		</Border>

		<!-- ── Context file row ── -->
		<Border DockPanel.Dock="Top"
			BorderThickness="0,0,0,1"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="6,3">
			<Grid ColumnDefinitions="Auto,*,Auto,Auto">
				<TextBlock Grid.Column="0" Text="Context:" FontSize="11"
					VerticalAlignment="Center" Margin="0,0,6,0" />
				<TextBlock Grid.Column="1"
					Text="{Binding ContextStatusText}"
					FontSize="11" VerticalAlignment="Center"
					Foreground="{StaticResource MesenTextMutedColor}"
					FontStyle="Italic" />
				<Button Grid.Column="2" Margin="4,0,0,0" Padding="6,2"
					Click="OnLoadContextClick"
					ToolTip.Tip="Load a text file to include as context in every prompt (memory map, known addresses, notes...)">
					<TextBlock Text="Load..." FontSize="11" />
				</Button>
				<Button Grid.Column="3" Margin="2,0,0,0" Padding="6,2"
					Command="{Binding ClearContextCommand}"
					IsVisible="{Binding Config.ContextFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
					ToolTip.Tip="Clear loaded context file">
					<TextBlock Text="✕" FontSize="11" />
				</Button>
			</Grid>
		</Border>

		<!-- ── Status bar ── -->
		<Border DockPanel.Dock="Bottom"
			BorderThickness="0,1,0,0"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="6,2">
			<TextBlock Text="{Binding StatusText}" FontSize="11" />
		</Border>

		<!-- ── Input row ── -->
		<Border DockPanel.Dock="Bottom"
			BorderThickness="0,1,0,0"
			BorderBrush="{StaticResource MesenBorderColor}"
			Padding="4">
			<Grid ColumnDefinitions="*,Auto">
				<TextBox Grid.Column="0"
					x:Name="txtInput"
					Text="{Binding InputText}"
					Watermark="Ask Claude about the code..."
					AcceptsReturn="False"
					KeyDown="OnInputKeyDown" />
				<Button Grid.Column="1" Margin="4,0,0,0" Padding="10,4"
					Click="OnSendCancelClick">
					<Panel>
						<TextBlock Text="Send" IsVisible="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
						<TextBlock Text="Cancel" IsVisible="{Binding IsBusy}" />
					</Panel>
				</Button>
			</Grid>
		</Border>

		<!-- ── Tabs: Chat + Review Queue ── -->
		<TabControl>

			<!-- Chat tab -->
			<TabItem Header="Chat">
				<ScrollViewer x:Name="chatScroll" HorizontalScrollBarVisibility="Disabled">
					<ItemsControl ItemsSource="{Binding Messages}" Margin="4">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:ChatEntry">
								<Panel Margin="2,3">

									<!-- User message: right-aligned bubble -->
									<Border IsVisible="{Binding IsUser}"
										Background="{StaticResource MesenBlueColor}"
										CornerRadius="6" Padding="8,5"
										HorizontalAlignment="Right" MaxWidth="480">
										<TextBlock Text="{Binding Text}"
											Foreground="White"
											TextWrapping="Wrap" FontSize="12" />
									</Border>

									<!-- Assistant message: left-aligned, monospace -->
									<Border IsVisible="{Binding IsAssistant}"
										Background="{StaticResource MesenGreenColor}"
										CornerRadius="6" Padding="8,5"
										HorizontalAlignment="Left" MaxWidth="560">
										<StackPanel>
											<TextBlock Text="{Binding Text}"
												TextWrapping="Wrap" FontFamily="Courier New,Monospace" FontSize="12" />
											<TextBlock IsVisible="{Binding IsStreaming}"
												Text="▌" FontSize="12" Opacity="0.5" />
										</StackPanel>
									</Border>

									<!-- Tool status: centered, muted italic -->
									<Border IsVisible="{Binding IsToolStatus}"
										Padding="4,1" HorizontalAlignment="Center">
										<TextBlock Text="{Binding Text}"
											FontSize="11"
											Foreground="{StaticResource MesenTextMutedColor}"
											FontStyle="Italic" />
									</Border>

									<!-- System message: centered, muted -->
									<Border IsVisible="{Binding IsSystem}"
										Padding="4,1" HorizontalAlignment="Center">
										<TextBlock Text="{Binding Text}"
											FontSize="11"
											Foreground="{StaticResource MesenTextMutedColor}"
											TextWrapping="Wrap" />
									</Border>

									<!-- Error: red banner -->
									<Border IsVisible="{Binding IsError}"
										Background="{StaticResource MesenErrorColor}"
										CornerRadius="4" Padding="8,5"
										HorizontalAlignment="Stretch">
										<TextBlock Text="{Binding Text}"
											Foreground="White"
											TextWrapping="Wrap" FontSize="12" />
									</Border>

								</Panel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</TabItem>

			<!-- Review Queue tab -->
			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal" Spacing="4">
						<TextBlock Text="Review Queue" VerticalAlignment="Center" />
						<Border Background="{StaticResource MesenBlueColor}"
							CornerRadius="8" Padding="5,1"
							IsVisible="{Binding ReviewQueueHasItems}">
							<TextBlock Text="{Binding ReviewQueue.Count}"
								Foreground="White" FontSize="10" VerticalAlignment="Center" />
						</Border>
					</StackPanel>
				</TabItem.Header>

				<DockPanel>
					<TextBlock DockPanel.Dock="Top" Margin="6,4"
						FontSize="11" TextWrapping="Wrap"
						Foreground="{StaticResource MesenTextMutedColor}"
						Text="Unannotated branch/sub targets encountered during execution. Click Analyze to ask Claude to annotate each one." />

					<ListBox ItemsSource="{Binding ReviewQueue}" Margin="4">
						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="ai:ReviewQueueItem">
								<Grid ColumnDefinitions="70,*,20,Auto" Margin="0,2">
									<TextBlock Grid.Column="0"
										Text="{Binding AddressDisplay}"
										FontFamily="Courier New,Monospace" FontSize="12"
										VerticalAlignment="Center" />
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1" Margin="4,0">
										<TextBlock Text="{Binding FlagsDisplay}"
											FontSize="11" FontWeight="Bold" />
										<TextBlock Text="{Binding Reason}"
											FontSize="10" TextWrapping="Wrap"
											IsVisible="{Binding Reason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
									</StackPanel>
									<TextBlock Grid.Column="2" Text="✓"
										IsVisible="{Binding IsAnalyzed}"
										Foreground="Green" FontSize="14"
										VerticalAlignment="Center" />
									<Button Grid.Column="3"
										Content="Analyze"
										Padding="6,2" FontSize="11"
										Click="OnAnalyzeClick"
										Tag="{Binding}" />
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</DockPanel>
			</TabItem>

		</TabControl>
	</DockPanel>
</Window>
